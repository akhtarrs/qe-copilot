# QE-Copilot Framework — .env Template
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Active URL (used by all actions at runtime) ───────────────────
BASE_URL=https://your-app.example.com

# ── Active API URL (used by api_catalog.json at runtime) ─────────
API_URL=https://your-app.example.com/api

# ── Environment URLs ──────────────────────────────────────────────
QA_BASE_URL=https://qa.your-app.example.com
QA_API_URL=https://qa.your-app.example.com/api
QA_DB_HOST=qa-db.your-app.example.com

UAT_BASE_URL=https://uat.your-app.example.com
UAT_API_URL=https://uat.your-app.example.com/api
UAT_DB_HOST=uat-db.your-app.example.com

PROD_BASE_URL=https://your-app.example.com
PROD_API_URL=https://your-app.example.com/api
PROD_DB_HOST=db.your-app.example.com

# ── User Credentials ──────────────────────────────────────────────
# Add one block per persona used in your test cases.
# Reference in testdata/users.yml as ${env.ADMIN_EMAIL} etc.

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

USER_EMAIL=user@example.com
USER_PASSWORD=changeme

# MANAGER_EMAIL=manager@example.com
# MANAGER_PASSWORD=changeme
